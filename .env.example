
# GitLab OAuth Configuration
GITLAB_APPLICATION_ID=your-gitlab-app-id
GITLAB_SECRET=your-gitlab-secret
GITLAB_REDIRECT_URI=http://localhost:3000/api/auth/gitlab/callback
GITLAB_BASE_URL=https://gitlab.com

# Claude Code API Configuration (for Fix with Agent feature)
ANTHROPIC_API_KEY=your-api-key
ANTHROPIC_BASE_URL=

# App Configuration
COOKIE_DOMAIN=localhost
APP_ENV=development
DOMAIN_NAME=your-domain.com
ACME_EMAIL=your-email@example.com

# Redis (optional, defaults to redis:6379 in Docker)
# REDIS_ADDR=redis:6379

